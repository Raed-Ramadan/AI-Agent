# Environment Variables Template for Instructor Companion
# Copy this file to .env and fill in your values

# OpenRouter API Key (enter in app, not here for security)
# OPENROUTER_API_KEY=your_api_key_here

# Optional: Custom base URL if needed
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Default temperature (set in app)
# DEFAULT_TEMPERATURE=0.7

# Optional: Subjects storage directory
# SUBJECTS_DIR=subjects